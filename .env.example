# Copy to `.env` and fill in. `.env` is gitignored.

# === LLM provider ===
# auto         → use ANTHROPIC_API_KEY if set, else local claude CLI
# claude_code  → force local claude CLI (dev / no-cost)
# anthropic    → force API
LLM_PROVIDER=auto
# ANTHROPIC_API_KEY=sk-ant-...

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=console

# === MCP (optional) ===
# GITHUB_TOKEN=ghp_...
# POSTGRES_READONLY_URL=postgresql://readonly:pw@host:5432/db
