      "Bash(curl -s http://127.0.0.1:8000/api/health)",
      "Bash(LLM_PROVIDER=ocbc .venv/bin/streamlit run:*)",
      "Bash(LLM_PROVIDER=ocbc .venv/bin/python:*)"
    ]
  }
}
