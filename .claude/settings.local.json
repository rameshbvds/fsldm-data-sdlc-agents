{
  "permissions": {
    "allow": [
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)",
      "WebFetch(domain:registry.npmjs.org)",
      "Bash(LLM_PROVIDER=claude_code .venv/bin/python -m agents.main run --dialect teradata --hitl-decision approve)",
