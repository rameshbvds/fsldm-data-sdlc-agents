FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
COPY pyproject.toml requirements-dev.txt ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements-dev.txt fastapi uvicorn[standard]
COPY agents/ ./agents/
COPY api/ ./api/
COPY schemas/ ./schemas/
RUN mkdir -p sql_teradata sql_dbt_gen sql_bteq gx soda data
ENV PYTHONIOENCODING=utf-8 PYTHONUTF8=1 PYTHONPATH=/app
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=5s CMD curl -f http://localhost:8000/api/health || exit 1
CMD ["uvicorn","api.server:app","--host","0.0.0.0","--port","8000"]
